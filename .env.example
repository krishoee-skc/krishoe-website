# Data backend
# Keep local-json during development.
# Use postgres only after repository adapters are implemented and migration smoke tests pass.
DATA_BACKEND="local-json"

# PostgreSQL connection string
# Example for a local database: postgres://user:password@localhost:5432/database_name
# Example for a Vercel Postgres: copy from Vercel project settings
DATABASE_URL=""

# SSL is validated by default on non-localhost connections (secure).
# PGSSLMODE="disable" turns SSL off (localhost only).
# PGSSL_INSECURE="true" skips certificate validation — ONLY for a provider
# with a self-signed chain; leave blank for Neon/Supabase/Vercel Postgres.
PGSSLMODE=""
PGSSL_INSECURE=""

# Admin bootstrap login.
# Leave email blank on /admin/login to use ADMIN_PASSWORD during setup.
# Create real staff accounts in /admin/settings before production.
ADMIN_PASSWORD=""
ADMIN_ROLE="Owner"
ADMIN_SESSION_SECRET=""
ADMIN_SESSION_TTL_SECONDS="28800"

# Customer account sessions
CUSTOMER_SESSION_SECRET=""
CUSTOMER_SESSION_TTL_SECONDS="2592000"
PASSWORD_RESET_SHOW_LOCAL_LINK="false"

# Payment gateways
# Use "manual" for normal inquiry/COD mode, "sandbox" for local gateway route tests.
# Do not use "live" until provider verification adapters are implemented.
PAYMENT_MODE="manual"
ESEWA_MERCHANT_ID=""
ESEWA_SECRET_KEY=""
ESEWA_CHECKOUT_URL=""
ESEWA_STATUS_CHECK_URL=""
ESEWA_VERIFY_WITH_STATUS_CHECK="false"
KHALTI_SECRET_KEY=""
KHALTI_CHECKOUT_URL=""
NEXT_PUBLIC_SITE_URL="http://localhost:3002"

# Optional notification integrations
ADMIN_NOTIFICATION_EMAIL=""
ADMIN_NOTIFICATION_PHONE=""
EMAIL_PROVIDER_URL=""
EMAIL_PROVIDER_TOKEN=""
SMS_PROVIDER_URL=""
SMS_PROVIDER_TOKEN=""
NOTIFICATION_WEBHOOK_URL=""
NOTIFICATION_WEBHOOK_TOKEN=""
NOTIFICATION_DELIVERY_TIMEOUT_MS="6000"

# Public business contact (shown on the storefront + used for WhatsApp/Viber orders).
# Defaults come from the shop's admin settings; override here per deployment.
# WhatsApp/Viber numbers must be full international format WITHOUT "+" for wa.me.
NEXT_PUBLIC_WHATSAPP_NUMBER="9779855019351"
NEXT_PUBLIC_VIBER_NUMBER="+9779855019351"
NEXT_PUBLIC_BUSINESS_PHONE="+977 9855019351"
NEXT_PUBLIC_BUSINESS_PHONE_TEL="+9779855019351"
NEXT_PUBLIC_BUSINESS_EMAIL="skschhapal@gmail.com"
NEXT_PUBLIC_BUSINESS_STREET="Pulchowk, Narayangadh"
NEXT_PUBLIC_BUSINESS_CITY="Bharatpur"
NEXT_PUBLIC_BUSINESS_REGION="Chitwan"
NEXT_PUBLIC_BUSINESS_POSTAL="44200"

# Social profiles (leave blank to hide; added to SEO schema + footer when set).
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""
NEXT_PUBLIC_TIKTOK_URL=""

# Marketing analytics (nothing loads until an id is set).
# Meta Pixel unlocks Facebook/Instagram ad retargeting + conversion tracking.
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GA4_ID=""
